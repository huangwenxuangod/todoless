{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "todoless",
  "version": "0.1.0",
  "identifier": "app.todoless.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "todoless",
        "width": 1020,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
