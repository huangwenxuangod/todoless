{
  "name": "@todoless/root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:desktop": "bun run --cwd apps/desktop tauri:dev",
    "build:desktop": "bun run --cwd apps/desktop tauri:build",
    "check:desktop": "bun run --cwd apps/desktop check",
    "dev:web": "bun run --cwd apps/web dev",
    "build:web": "bun run --cwd apps/web build",
    "dev:app": "bun run --cwd apps/app start",
    "db:start": "supabase start",
    "db:types": "supabase gen types typescript --local > packages/shared/src/sync/schema.ts"
  },
  "devDependencies": {
    "typescript": "latest"
  },
  "dependencies": {
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-sqlite": "~15.1.4",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0"
  }
}
